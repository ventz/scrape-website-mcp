# OPTIONAL — only needed if you call this MCP server's OpenAI-side tools
# (register_url / resync_url / resync_all / unregister_url / list_registered)
# directly from an external MCP client.
#
# When this server is wired into the Harvard EA assistants platform via the
# "Scrape Website (self-hosted)" prebuilt, the platform handles all OpenAI
# uploads itself using the agent's own key. In that case the platform only
# ever calls `fetch_url_as_markdown`, which has no OpenAI dependency, and
# you can leave OPENAI_API_KEY blank.
#
# Precedence: a value here OVERRIDES the parent shell env. Leave commented
# out to fall back to shell env. Same applies to MCP_BEARER_TOKEN below.
# OPENAI_API_KEY=sk-...

# Required: bearer token that the assistants platform (or any MCP client)
# must present in the Authorization header to use this server.
# Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=changeme

# Optional: SQLite state directory (default: ./data)
STATE_DIR=./data

# Optional: pin which ref of ventz/scrape-website to use at build/setup time.
# Used by Dockerfile (build arg) and Makefile. Set to "main" for HEAD.
SCRAPE_WEBSITE_REF=main

# Optional: User-Agent override for outbound scrapes.
SCRAPER_USER_AGENT=scrape-website-mcp/0.1
